# Deployment Mode
DEPLOYMENT_MODE=SAAS  # SAAS o SELF_HOSTED

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/creditflow?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# API
PORT=3001
NODE_ENV=development

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# License (solo para SELF_HOSTED)
LICENSE_FILE_PATH=./config/license.key
LICENSE_PUBLIC_KEY_PATH=./keys/public.pem

# Stripe (solo para SAAS)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Redis (opcional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logs
LOG_LEVEL=debug  # error, warn, info, debug
