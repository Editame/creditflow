// Prisma schema for CreditFlow
// Multi-tenant with SaaS and Self-Hosted support

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum DeploymentMode {
  SAAS
  SELF_HOSTED
}

enum Plan {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  COLLECTOR
  ACCOUNTANT
}

enum PaymentFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum LoanStatus {
  ACTIVE
  PAID
  OVERDUE
}

enum ConceptType {
  DISCOUNT
  COST
}

enum PaidBy {
  CLIENT
  COLLECTOR
}

enum FeatureModule {
  CLIENTS_BASIC
  LOANS_BASIC
  PAYMENTS_BASIC
  ROUTES_BASIC
  EXPENSES
  REPORTS_ADVANCED
  USERS_MANAGEMENT
  API_REST
  EXPORT_EXCEL
  CONCEPTS_CUSTOM
  REFINANCING
  ROLES_PERMISSIONS
  WHITE_LABEL
  CUSTOM_DOMAIN
  WEBHOOKS
  SSO
  AUDIT_LOGS
  CUSTOM_REPORTS
}

enum CashMovementType {
  IN
  OUT
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

// ============================================
// TENANT
// ============================================

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  
  mode        DeploymentMode @default(SAAS)
  plan        Plan     @default(BASIC)
  active      Boolean  @default(true)
  
  maxRoutes   Int      @default(1)
  maxClients  Int      @default(100)
  maxUsers    Int      @default(2)
  
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   SubscriptionStatus?
  trialEndsAt          DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]
  routes      Route[]
  clients     Client[]
  loans       Loan[]
  payments    Payment[]
  expenses    Expense[]
  features    TenantFeature[]
  auditLogs   AuditLog[]
  chargeConcepts ChargeConcept[]
  refinancings Refinancing[]
  cashRegisters CashRegister[]
  cashMovementConcepts CashMovementConcept[]
  
  @@index([slug])
  @@index([active])
}

// ============================================
// TENANT FEATURES
// ============================================

model TenantFeature {
  id         String        @id @default(uuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  module     FeatureModule
  enabled    Boolean       @default(true)
  limit      Int?
  used       Int           @default(0)
  
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  
  @@unique([tenantId, module])
  @@index([tenantId])
}

// ============================================
// LICENSE
// ============================================

model License {
  id            String    @id @default(uuid())
  licenseKey    String    @unique
  tenantName    String
  contactEmail  String
  plan          Plan
  modules       FeatureModule[]
  maxRoutes     Int
  maxClients    Int
  maxUsers      Int
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?
  supportEndsAt DateTime?
  version       String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([licenseKey])
  @@index([isActive])
}

// ============================================
// USERS
// ============================================

model User {
  id        Int       @id @default(autoincrement())
  tenantId  String?   // NULL para SUPER_ADMIN
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  username  String
  fullName  String?
  email     String?
  password  String
  role      UserRole  @default(COLLECTOR)
  active    Boolean   @default(true)
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?
  
  payments  Payment[] @relation("PaymentsCollector")
  auditLogs AuditLog[]
  loansCreated Loan[] @relation("LoansCreated")
  refinancings Refinancing[] @relation("RefinancingsCreated")
  
  @@unique([tenantId, username])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, active])
}

// ============================================
// ROUTES
// ============================================

model Route {
  id          Int      @id @default(autoincrement())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  active      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  budgets     RouteBudget[]
  expenses    Expense[]
  clients     Client[]
  payments    Payment[]
  cashRegisters CashRegister[]
  
  @@index([tenantId])
  @@index([tenantId, active])
}

// ============================================
// BUDGETS
// ============================================

model RouteBudget {
  id             Int      @id @default(autoincrement())
  routeId        Int
  route          Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  month          Int
  year           Int
  assignedAmount Decimal  @default(0) @db.Decimal(10, 2)
  spentAmount    Decimal  @default(0) @db.Decimal(10, 2)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@unique([routeId, month, year])
  @@index([routeId])
}

// ============================================
// EXPENSES
// ============================================

model Expense {
  id          Int      @id @default(autoincrement())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  routeId     Int
  route       Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  amount      Decimal  @db.Decimal(10, 2)
  description String
  category    String?
  date        DateTime @default(now())
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([tenantId])
  @@index([routeId])
  @@index([date])
}

// ============================================
// CLIENTS
// ============================================

model Client {
  id             Int      @id @default(autoincrement())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  routeId        Int
  route          Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  idNumber       String
  fullName       String
  phone          String?
  address        String?
  idPhotoUrl     String?
  active         Boolean  @default(true)
  blocked        Boolean  @default(false)
  blockReason    String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  loans          Loan[]
  
  @@unique([tenantId, idNumber])
  @@index([tenantId])
  @@index([tenantId, active])
  @@index([routeId])
}

// ============================================
// CHARGE CONCEPTS
// ============================================

model ChargeConcept {
  id          Int      @id @default(autoincrement())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  percentage  Decimal  @db.Decimal(5, 2)
  type        ConceptType @default(DISCOUNT)
  isCalculated Boolean  @default(true)
  description String?
  active      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  discounts   LoanDiscount[]
  costs       LoanCost[]
  
  @@index([tenantId])
}

model LoanDiscount {
  id             Int      @id @default(autoincrement())
  loanId         Int
  conceptId      Int
  discountAmount Decimal  @db.Decimal(12, 2)
  percentage     Decimal  @db.Decimal(5, 2)
  
  loan           Loan @relation(fields: [loanId], references: [id])
  concept        ChargeConcept @relation(fields: [conceptId], references: [id])
  
  createdAt      DateTime @default(now())
}

model LoanCost {
  id         Int      @id @default(autoincrement())
  loanId     Int
  conceptId  Int
  costAmount Decimal  @db.Decimal(12, 2)
  percentage Decimal  @db.Decimal(5, 2)
  
  loan       Loan @relation(fields: [loanId], references: [id])
  concept    ChargeConcept @relation(fields: [conceptId], references: [id])
  
  createdAt  DateTime @default(now())
}

// ============================================
// LOANS
// ============================================

model Loan {
  id                 Int            @id @default(autoincrement())
  tenantId           String
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  clientId           Int
  client             Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  loanAmount         Decimal        @db.Decimal(12, 2)
  receivedAmount     Decimal        @db.Decimal(12, 2) @default(0)
  totalDiscounts     Decimal        @db.Decimal(12, 2) @default(0)
  totalCosts         Decimal        @db.Decimal(12, 2) @default(0)
  disbursedAmount    Decimal        @db.Decimal(12, 2) @default(0)
  interestRate       Decimal        @db.Decimal(5, 2)
  paymentFrequency   PaymentFrequency
  installmentValue   Decimal        @db.Decimal(10, 2)
  pendingBalance     Decimal        @db.Decimal(12, 2)
  
  disbursementDate   DateTime
  collectionStartDate DateTime
  endDate            DateTime
  originalEndDate    DateTime?
  status             LoanStatus @default(ACTIVE)
  
  createdById        Int?
  createdBy          User?       @relation("LoansCreated", fields: [createdById], references: [id], onDelete: SetNull)
  
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  
  payments           Payment[]
  discounts          LoanDiscount[]
  costs              LoanCost[]
  refinancingsFrom   Refinancing[] @relation("PreviousLoan")
  refinancingsTo     Refinancing[] @relation("NewLoan")
  
  @@index([tenantId])
  @@index([clientId])
  @@index([tenantId, status])
  @@index([disbursementDate])
}

// ============================================
// REFINANCING
// ============================================

model Refinancing {
  id                     Int      @id @default(autoincrement())
  tenantId               String
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  previousLoanId         Int
  newLoanId              Int
  previousLoan           Loan @relation("PreviousLoan", fields: [previousLoanId], references: [id])
  newLoan                Loan @relation("NewLoan", fields: [newLoanId], references: [id])
  
  previousPendingBalance Decimal  @db.Decimal(12, 2)
  newAmount              Decimal  @db.Decimal(12, 2)
  deliveredAmount        Decimal  @db.Decimal(12, 2)
  
  refinancingReason      String?
  refinancingDate        DateTime @default(now())
  createdById            Int
  createdBy              User  @relation("RefinancingsCreated", fields: [createdById], references: [id])
  
  createdAt              DateTime @default(now())
  
  @@index([tenantId])
  @@index([refinancingDate])
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id            Int      @id @default(autoincrement())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  loanId        Int
  loan          Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  
  collectorId   Int
  collector     User  @relation("PaymentsCollector", fields: [collectorId], references: [id])
  
  routeId       Int
  route         Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  amountPaid    Decimal  @db.Decimal(10, 2)
  paidBy        PaidBy @default(CLIENT)
  paymentDate   DateTime @default(now())
  notes         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([tenantId])
  @@index([loanId])
  @@index([collectorId])
  @@index([routeId])
  @@index([paymentDate])
  @@index([paidBy])
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId      Int?
  user        User? @relation(fields: [userId], references: [id])
  
  action      String
  entity      String
  entityId    String
  
  oldData     Json?
  newData     Json?
  
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  @@index([tenantId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ============================================
// CASH REGISTER (CAJA)
// ============================================

model CashRegister {
  id          Int      @id @default(autoincrement())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  routeId     Int?     // NULL = caja global
  route       Route?   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  name        String
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  active      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  movements   CashMovement[]
  
  @@unique([tenantId, routeId])
  @@index([tenantId])
}

model CashMovementConcept {
  id          Int              @id @default(autoincrement())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  type        CashMovementType
  description String?
  isSystem    Boolean          @default(false) // true = auto-generado (prestamo, pago, gasto)
  active      Boolean          @default(true)
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  movements   CashMovement[]
  
  @@index([tenantId])
}

model CashMovement {
  id              Int              @id @default(autoincrement())
  cashRegisterId  Int
  cashRegister    CashRegister     @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  
  conceptId       Int
  concept         CashMovementConcept @relation(fields: [conceptId], references: [id])
  
  type            CashMovementType
  amount          Decimal          @db.Decimal(12, 2)
  balanceAfter    Decimal          @db.Decimal(12, 2)
  description     String?
  
  // Referencias opcionales para trazabilidad
  loanId          Int?
  paymentId       Int?
  expenseId       Int?
  
  createdById     Int?
  date            DateTime         @default(now())
  createdAt       DateTime         @default(now())
  
  @@index([cashRegisterId])
  @@index([date])
  @@index([type])
}

// ============================================
// ROLES & PERMISSIONS
// ============================================

model Role {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  permissions RolePermission[]
  
  @@unique([name])
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  module      String
  
  createdAt   DateTime @default(now())
  
  roles       RolePermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
  
  @@unique([roleId, permissionId])
}